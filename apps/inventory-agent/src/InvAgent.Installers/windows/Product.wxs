<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Toolset v4 installer definition for Meridian Inventory Agent (Windows)
  Install path:  %ProgramFiles%\Meridian\Agent\
  Config path:   %ProgramData%\Meridian\config.json
  Service name:  MeridianAgent (auto-start, LocalSystem)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Meridian Inventory Agent"
           Manufacturer="Meridian ITSM"
           Version="1.0.0.0"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Meridian Inventory Agent is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="MeridianDir" Name="Meridian">
        <Directory Id="INSTALLFOLDER" Name="Agent" />
      </Directory>
    </StandardDirectory>

    <!-- Config directory under ProgramData -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="MeridianDataDir" Name="Meridian" />
    </StandardDirectory>

    <!-- Main component: agent binary and files -->
    <ComponentGroup Id="AgentComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentExe">
        <File Id="AgentExeFile"
              Source="$(var.PublishDir)\InvAgent.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="AgentDeps">
        <!-- Include all DLLs from publish directory -->
        <File Source="$(var.PublishDir)\InvAgent.dll" />
        <File Source="$(var.PublishDir)\InvAgent.runtimeconfig.json" />
      </Component>
    </ComponentGroup>

    <!-- Default config file -->
    <ComponentGroup Id="ConfigComponents" Directory="MeridianDataDir">
      <Component Id="AgentConfig">
        <File Id="AgentConfigFile"
              Source="$(var.ProjectDir)\windows\config.default.json"
              Name="config.json"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Windows Service registration -->
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentService">
        <ServiceInstall Id="AgentServiceInstall"
                        Name="MeridianAgent"
                        DisplayName="Meridian Inventory Agent"
                        Description="Collects hardware and software inventory for Meridian ITSM."
                        Start="auto"
                        Type="ownProcess"
                        Account="LocalSystem"
                        ErrorControl="normal" />
        <ServiceControl Id="AgentServiceControl"
                        Name="MeridianAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
        <KeyPath Id="AgentServiceKey" />
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="Meridian Inventory Agent" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="ConfigComponents" />
      <ComponentGroupRef Id="ServiceComponents" />
    </Feature>

  </Package>
</Wix>
