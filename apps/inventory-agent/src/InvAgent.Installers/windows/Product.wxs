<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v6 installer for Meridian Inventory Agent (Windows)

  Silent install:
    msiexec /i MeridianAgent.msi SERVER_URL="https://..." ENROLLMENT_TOKEN="..." /quiet

  Interactive:
    Double-click MeridianAgent.msi

  Build (run via build-installer.ps1, which reads Version from Directory.Build.props):
    wix build Product.wxs -d Version=1.0.0.2 -d PublishDir=...\publish\win-x64-installer -d ProjectDir=...\src\InvAgent.Installers -o MeridianAgent.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Meridian Inventory Agent"
           Manufacturer="Meridian ITSM"
           Version="$(var.Version)"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Description="Meridian ITSM Inventory Agent" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Meridian Inventory Agent is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ── Public Properties (settable via msiexec CLI) ─────────────────── -->
    <Property Id="SERVER_URL" Secure="yes" />
    <Property Id="ENROLLMENT_TOKEN" Secure="yes" />
    <Property Id="PRIVACY_TIER" Value="full" Secure="yes" />

    <!-- ── Directories ──────────────────────────────────────────────────── -->
    <!-- ProgramFiles64Folder → C:\Program Files on x64 Windows. The self-contained
         win-x64 .NET runtime must live under the 64-bit path; ProgramFilesFolder
         would resolve to C:\Program Files (x86) and the service host would fail
         to locate the x64 InvAgent.exe at StartServices time. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="MeridianDir" Name="Meridian">
        <Directory Id="INSTALLFOLDER" Name="Agent" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="MeridianDataDir" Name="Meridian" />
    </StandardDirectory>

    <!-- ── All agent files EXCEPT InvAgent.exe (service binary lives in its own
         component below so its File Id anchors the service's ImagePath). ───── -->
    <ComponentGroup Id="AgentFiles" Directory="INSTALLFOLDER" Source="$(var.PublishDir)">
      <Files Include="**;!InvAgent.exe" />
    </ComponentGroup>

    <!-- ── Config directory ──────────────────────────────────────────────── -->
    <ComponentGroup Id="ConfigComponents" Directory="MeridianDataDir">
      <Component Id="ConfigDir" Guid="F2B3C4D5-E6F7-8901-2345-6789ABCDEF01">
        <CreateFolder />
        <RemoveFolder Id="RemoveConfigDir" On="uninstall" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\Meridian\Agent" Name="ConfigDir" Type="string" Value="[MeridianDataDir]" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Windows Service ──────────────────────────────────────────────── -->
    <!-- The service binary (InvAgent.exe) MUST live in the same Component as the
         ServiceInstall — Windows Installer derives the service's ImagePath from
         the Component's KeyPath file. With a registry-only KeyPath, ImagePath is
         empty and StartService times out after 30 s with Error 1920. -->
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentService" Guid="A3B4C5D6-E7F8-9012-3456-789ABCDEF012">
        <File Id="InvAgentExe" Source="$(var.PublishDir)\InvAgent.exe" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\Meridian\Agent" Name="ServiceInstalled" Type="integer" Value="1" />
        <ServiceInstall Id="AgentServiceInstall"
                        Name="MeridianAgent"
                        DisplayName="Meridian Inventory Agent"
                        Description="Collects hardware and software inventory for Meridian ITSM."
                        Start="auto"
                        Type="ownProcess"
                        Account="LocalSystem"
                        ErrorControl="normal" />
        <!-- Start="install" runs at StartServices (seq 5900), after WriteConfigCA
             (seq ~5801). On MajorUpgrade it restarts the service post-replacement. -->
        <ServiceControl Id="AgentServiceControl"
                        Name="MeridianAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

    <!-- Write config.json after files are installed, before StartServices.
         NOT Installed = fresh install only; MajorUpgrade preserves existing config.
         We invoke a bundled PowerShell script rather than `cmd /c echo` because
         MSI's Formatted type strips `{...}` as conditional-substring markers,
         which mangles JSON. The helper script takes named args (no `{}` in the
         ExeCommand string) and writes UTF-8 JSON via ConvertTo-Json. -->
    <CustomAction Id="WriteConfigCA"
                  Directory="INSTALLFOLDER"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]write-config.ps1&quot; -ServerUrl &quot;[SERVER_URL]&quot; -EnrollmentToken &quot;[ENROLLMENT_TOKEN]&quot; -PrivacyTier &quot;[PRIVACY_TIER]&quot; -OutputPath &quot;[MeridianDataDir]config.json&quot;'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
      <Custom Action="WriteConfigCA" After="InstallServices" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- ── Features ─────────────────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="Meridian Inventory Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentGroupRef Id="ConfigComponents" />
      <ComponentGroupRef Id="ServiceComponents" />
    </Feature>

    <!-- ── Logo for Add/Remove Programs ─────────────────────────────────── -->
    <Icon Id="MeridianIcon" SourceFile="$(var.ProjectDir)\windows\meridian-logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="MeridianIcon" />

  </Package>
</Wix>
