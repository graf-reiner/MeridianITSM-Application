[Unit]
Description=Meridian Inventory Agent
Documentation=https://docs.meridianitesm.com/agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/meridian-agent/InvAgent
Restart=always
RestartSec=30
TimeoutStartSec=60
TimeoutStopSec=30
User=meridian-agent
Group=meridian-agent
WorkingDirectory=/opt/meridian-agent
Environment=DOTNET_CLI_TELEMETRY_OPTOUT=1
EnvironmentFile=-/etc/meridian-agent/environment

# Harden the service. ReadWritePaths must reference dirs that exist at start
# time — the .deb / .rpm postinst is responsible for creating each one.
# PrivateTmp=yes is required: System.CommandLine writes a sentinel file under
# /tmp on first invocation, and ProtectSystem=strict makes the host /tmp
# read-only. PrivateTmp gives the service its own writable /tmp namespace.
#
# NoNewPrivileges deliberately NOT set: the self-update path needs sudo to
# invoke dpkg/rpm + systemctl restart (limited to exact paths via
# /etc/sudoers.d/meridian-agent), and NoNewPrivileges blocks setuid binaries
# inside the cgroup. The non-root User= + narrow sudoers fragment provide
# the privilege boundary instead.
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/etc/meridian-agent /var/log/meridian-agent /var/lib/meridian-agent

[Install]
WantedBy=multi-user.target
