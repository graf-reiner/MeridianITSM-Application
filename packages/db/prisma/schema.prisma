// ─── Supporting ───────────────────────────────────────────────────────────────

// Model 51: Vendor
model Vendor {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  name           String
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  website        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  contracts Contract[]

  @@index([tenantId])
  @@map("vendors")
}

// Model 52: Contract
model Contract {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  vendorId        String?  @db.Uuid
  name            String
