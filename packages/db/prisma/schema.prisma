generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantType {
  MSP
  ENTERPRISE
  B2C
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionPlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketType {
  INCIDENT
  SERVICE_REQUEST
  PROBLEM
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommentVisibility {
  PUBLIC
  INTERNAL
}

enum ChangeStatus {
  NEW
  ASSESSMENT
  APPROVAL_PENDING
  APPROVED
  REJECTED
  SCHEDULED
  IMPLEMENTING
  REVIEW
  COMPLETED
  CANCELLED
}

enum ChangeType {
  STANDARD
  NORMAL
  EMERGENCY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetStatus {
  IN_STOCK
  DEPLOYED
  IN_REPAIR
  RETIRED
  DISPOSED
}

enum AgentStatus {
  ENROLLING
  ACTIVE
  OFFLINE
  SUSPENDED
}

enum AgentPlatform {
  WINDOWS
  LINUX
  MACOS
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  RETIRED
}

enum ArticleVisibility {
  PUBLIC
  INTERNAL
}

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_UPDATED
  TICKET_COMMENTED
  TICKET_RESOLVED
  TICKET_CREATED
  SLA_WARNING
  SLA_BREACH
  CHANGE_APPROVAL
  CHANGE_UPDATED
  MENTION
  SYSTEM
  CAB_INVITATION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  ASSIGN
  ESCALATE
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum CmdbCiStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
  PLANNED
}

enum CmdbCiType {
  SERVER
  WORKSTATION
  NETWORK_DEVICE
  SOFTWARE
  SERVICE
  DATABASE
  VIRTUAL_MACHINE
  CONTAINER
  OTHER
}

enum CmdbCiEnvironment {
  PRODUCTION
  STAGING
  DEV
  DR
}

enum CmdbRelationshipType {
  DEPENDS_ON
  HOSTS
  CONNECTS_TO
  RUNS_ON
  BACKS_UP
  VIRTUALIZES
  MEMBER_OF
}

enum CmdbChangeType {
  CREATED
  UPDATED
  DELETED
}

enum CmdbChangedBy {
  USER
  AGENT
  IMPORT
}

enum CmdbTicketLinkType {
  AFFECTED
  RELATED
  CAUSED_BY
}

enum CABAttendeeRole {
  CHAIRPERSON
  MEMBER
  OBSERVER
}

enum RSVPStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum CABOutcome {
  APPROVED
  REJECTED
  DEFERRED
  NEEDS_MORE_INFO
}

enum CABMeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationType {
  WEB
  MOBILE
  DESKTOP
  API
  SERVICE
  DATABASE_APP
  MIDDLEWARE
  INFRASTRUCTURE
  OTHER
}

enum ApplicationStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
  PLANNED
  IN_DEVELOPMENT
}

enum CriticalityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HostingModel {
  ON_PREMISE
  CLOUD
  HYBRID
  SAAS
}

enum LifecycleStage {
  PLANNING
  DEVELOPMENT
  PRODUCTION
  RETIREMENT
}

enum DependencyType {
  DATA_FLOW
  API_CALL
  SHARED_DATABASE
  AUTHENTICATION
  FILE_TRANSFER
  MESSAGE_QUEUE
  OTHER
}

enum DocumentType {
  ARCHITECTURE
  API_SPEC
  RUNBOOK
  SLA_DOC
  SECURITY
  COMPLIANCE
  USER_GUIDE
  ADMIN_GUIDE
  RELEASE_NOTES
  DEPLOYMENT
  OTHER
}

enum AppAssetRelationship {
  RUNS_ON
  HOSTED_BY
  USES
}

enum WebhookEventType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_RESOLVED
  TICKET_CLOSED
  COMMENT_ADDED
  CHANGE_CREATED
  CHANGE_APPROVED
  SLA_BREACH
}

enum AlertChannelType {
  EMAIL
  SMS
  SLACK
  TEAMS
}

// ─── Core Tenancy & Identity ──────────────────────────────────────────────────

// Model 1: Tenant (GLOBAL — no tenantId)
model Tenant {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  slug           String               @unique
  type           TenantType           @default(MSP)
  status         TenantStatus         @default(ACTIVE)
  subdomain      String?              @unique
  backendUrl     String?
  settings       Json?
  plan           SubscriptionPlanTier @default(STARTER)
  planLimitsJson Json?
  maxUsers       Int                  @default(5)
  maxAgents      Int                  @default(0)
  maxSites       Int                  @default(1)
  trialEndsAt    DateTime?
  suspendedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  // Relations
  users                 User[]
  customerOrganizations CustomerOrganization[]
  userGroups            UserGroup[]
  roles                 Role[]
  userRoles             UserRole[]
  sessions              Session[]
  apiKeys               ApiKey[]
  tickets               Ticket[]
  ticketComments        TicketComment[]
  ticketAttachments     TicketAttachment[]
  ticketActivities      TicketActivity[]
  queues                Queue[]
  slas                  SLA[]
  categories            Category[]
  emailAccounts         EmailAccount[]
  changes               Change[]
  changeApprovals       ChangeApproval[]
  changeActivities      ChangeActivity[]
  cabMeetings           CABMeeting[]
  cabMeetingAttendees   CABMeetingAttendee[]
  cabMeetingChanges     CABMeetingChange[]
  knowledgeArticles     KnowledgeArticle[]
  assets                Asset[]
  sites                 Site[]
  businessUnits         BusinessUnit[]
  applications          Application[]
  applicationActivities     ApplicationActivity[]
  applicationDependencies   ApplicationDependency[]
  applicationDocuments      ApplicationDocument[]
  applicationAssets         ApplicationAsset[]
  agents                    Agent[]
  agentEnrollmentTokens AgentEnrollmentToken[]
  inventorySnapshots    InventorySnapshot[]
  metricSamples         MetricSample[]
  cmdbCategories        CmdbCategory[]
  cmdbConfigItems       CmdbConfigurationItem[]
  cmdbRelationships     CmdbRelationship[]
  cmdbChangeRecords     CmdbChangeRecord[]
  cmdbTicketLinks       CmdbTicketLink[]
  changeApplications    ChangeApplication[]
  changeAssets          ChangeAsset[]
  contractAssets        ContractAsset[]
  ticketKnowledgeArticles TicketKnowledgeArticle[]
  vendors               Vendor[]
  contracts             Contract[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  deviceTokens          DeviceToken[]
  emailTemplates        EmailTemplate[]
  alertConfigurations   AlertConfiguration[]
  notificationRules    NotificationRule[]
  notificationRuleLogs NotificationRuleLog[]
  scheduledReports      ScheduledReport[]
  webhooks              Webhook[]
  webhookDeliveries     WebhookDelivery[]
  passwordResetTokens   PasswordResetToken[]
  userGroupMembers      UserGroupMember[]
  subscription          TenantSubscription?
  usageSnapshots        TenantUsageSnapshot[]
  ownerNotes            OwnerNote[]
  tags                  Tag[]
  ssoConnections        SsoConnection[]
  tenantAuthSettings    TenantAuthSettings?
  mfaTrustedDevices     MfaTrustedDevice[]
  emailActivityLogs     EmailActivityLog[]

  @@map("tenants")
}

// Model 2: CustomerOrganization
model CustomerOrganization {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  name                 String
  slug                 String
  primaryContactName   String?
  primaryContactEmail  String?
  primaryContactPhone  String?
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("customer_organizations")
}

// Model 3: User
model User {
  id                      String     @id @default(uuid()) @db.Uuid
  tenantId                String     @db.Uuid
  email                   String
  passwordHash            String
  firstName               String
  lastName                String
  displayName             String?
  phone                   String?
  jobTitle                String?
  department              String?
  status                  UserStatus @default(ACTIVE)
  notificationPreferences Json?
  pushPreferences         Json?
  siteId                  String?    @db.Uuid
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  site                Site?                @relation(fields: [siteId], references: [id])
  userRoles           UserRole[]
  sessions            Session[]
  assignedTickets     Ticket[]             @relation("AssignedTo")
  requestedTickets    Ticket[]             @relation("RequestedBy")
  ticketComments      TicketComment[]
  ticketAttachments   TicketAttachment[]
  cabMeetingAttendees CABMeetingAttendee[]
  changeApprovals     ChangeApproval[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  auditLogs           AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  userGroupMembers     UserGroupMember[]
  apiKeys              ApiKey[]
  federatedIdentities  FederatedIdentity[]
  mfaDevices           MfaDevice[]
  mfaChallenges        MfaChallenge[]
  recoveryCodes        RecoveryCode[]
  mfaTrustedDevices    MfaTrustedDevice[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("users")
}

// Model 4: UserGroup
model UserGroup {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  email       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  userGroupMembers UserGroupMember[]
  categories      Category[]
  queues          Queue[]
  ticketsAssigned  Ticket[] @relation("TicketAssignedGroup")

  @@index([tenantId])
  @@map("user_groups")
}

// Model 5: UserGroupMember (extra join table)
model UserGroupMember {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  userGroupId String   @db.Uuid
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userGroup UserGroup @relation(fields: [userGroupId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userGroupId, userId])
  @@index([tenantId])
  @@map("user_group_members")
}

// Model 6: Role
model Role {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  slug         String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

// Model 7: UserRole
model UserRole {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @db.Uuid
  userId                 String   @db.Uuid
  roleId                 String   @db.Uuid
  customerOrganizationId String?  @db.Uuid
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
  role                 Role                  @relation(fields: [roleId], references: [id])
  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id])

  @@unique([userId, roleId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("user_roles")
}

// Model 8: Session
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  userId       String   @db.Uuid
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("sessions")
}

// Model 9: ApiKey
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  userId     String    @db.Uuid
  name       String
  keyHash    String
  keyPrefix  String
  scopes     Json
  rateLimit  Int       @default(100)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── Service Desk ─────────────────────────────────────────────────────────────

// Model 10: Ticket
model Ticket {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  ticketNumber   Int
  type           TicketType     @default(INCIDENT)
  title          String
  description    String?
  priority       TicketPriority @default(MEDIUM)
  impact         String?
  urgency        String?
  status         TicketStatus   @default(NEW)
  assignedToId   String?        @db.Uuid
  assignedGroupId String?       @db.Uuid
  requestedById  String?        @db.Uuid
  queueId        String?        @db.Uuid
  slaId          String?        @db.Uuid
  categoryId     String?        @db.Uuid
  slaBreachAt    DateTime?
  slaResponseAt  DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  resolution     String?
  tags           String[]
  customFields   Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  assignedTo          User?                  @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedGroup       UserGroup?             @relation("TicketAssignedGroup", fields: [assignedGroupId], references: [id])
  requestedBy         User?                  @relation("RequestedBy", fields: [requestedById], references: [id])
  queue               Queue?                 @relation(fields: [queueId], references: [id])
  sla                 SLA?                   @relation(fields: [slaId], references: [id])
  category            Category?              @relation(fields: [categoryId], references: [id])
  comments            TicketComment[]
  attachments         TicketAttachment[]
  activities          TicketActivity[]
  knowledgeArticles   TicketKnowledgeArticle[]
  cmdbTicketLinks     CmdbTicketLink[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, assignedToId])
  @@index([tenantId, createdAt])
  @@index([tenantId, slaBreachAt])
  @@map("tickets")
}

// Model 11: TicketComment
model TicketComment {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  ticketId         String            @db.Uuid
  authorId         String            @db.Uuid
  content          String
  visibility       CommentVisibility @default(PUBLIC)
  timeSpentMinutes Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_comments")
}

// Model 12: TicketAttachment
model TicketAttachment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  ticketId    String   @db.Uuid
  uploadedById String  @db.Uuid
  filename    String
  mimeType    String
  fileSize    Int
  storagePath String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  ticket     Ticket @relation(fields: [ticketId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

// Model 13: TicketActivity
model TicketActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  ticketId     String   @db.Uuid
  actorId      String?  @db.Uuid
  activityType String
  fieldName    String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@index([tenantId, createdAt])
  @@map("ticket_activities")
}

// Model 14: TicketKnowledgeArticle
model TicketKnowledgeArticle {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  ticketId          String   @db.Uuid
  knowledgeArticleId String  @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  ticket           Ticket           @relation(fields: [ticketId], references: [id])
  knowledgeArticle KnowledgeArticle @relation(fields: [knowledgeArticleId], references: [id])

  @@unique([ticketId, knowledgeArticleId])
  @@index([tenantId])
  @@map("ticket_knowledge_articles")
}

// Model 15: Queue
model Queue {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  autoAssign        Boolean  @default(false)
  defaultAssigneeId String?  @db.Uuid
  userGroupId       String?  @db.Uuid
  assignmentRules   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userGroup UserGroup? @relation(fields: [userGroupId], references: [id])
  tickets           Ticket[]
  notificationRules NotificationRule[]

  @@index([tenantId])
  @@map("queues")
}

// Model 16: SLA
model SLA {
  id                        String   @id @default(uuid()) @db.Uuid
  tenantId                  String   @db.Uuid
  name                      String
  p1ResponseMinutes         Int
  p1ResolutionMinutes       Int
  p2ResponseMinutes         Int
  p2ResolutionMinutes       Int
  p3ResponseMinutes         Int
  p3ResolutionMinutes       Int
  p4ResponseMinutes         Int
  p4ResolutionMinutes       Int
  businessHours             Boolean  @default(true)
  businessHoursStart        String?
  businessHoursEnd          String?
  businessDays              Int[]
  timezone                  String   @default("UTC")
  autoEscalate              Boolean  @default(false)
  escalateToQueueId         String?  @db.Uuid
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("slas")
}

// Model 17: Category
model Category {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  icon        String?
  color       String?
  parentId    String?  @db.Uuid
  userGroupId String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  parent     Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryParent")
  userGroup  UserGroup? @relation(fields: [userGroupId], references: [id])
  tickets    Ticket[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

// Model 18: EmailAccount
model EmailAccount {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  emailAddress      String
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPasswordEnc   String?
  smtpSecure        Boolean  @default(true)
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPasswordEnc   String?
  imapSecure        Boolean  @default(true)
  pollInterval      Int      @default(5)
  isActive          Boolean  @default(true)
  emailToTicket     Boolean  @default(true)
  defaultQueueId    String?  @db.Uuid
  defaultCategoryId String?  @db.Uuid
  lastPolledAt      DateTime?
  lastProcessedUid  Int       @default(0)

  // OAuth2
  authProvider          String    @default("MANUAL")  // MANUAL, GOOGLE, MICROSOFT
  oauthAccessTokenEnc   String?
  oauthRefreshTokenEnc  String?
  oauthTokenExpiresAt   DateTime?
  oauthScope            String?
  oauthConnectionStatus String?   // CONNECTED, DISCONNECTED, REFRESH_FAILED

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  activityLogs EmailActivityLog[]
  pollJob      EmailPollJob?

  @@index([tenantId])
  @@map("email_accounts")
}

// ─── Email Activity Log ──────────────────────────────────────────────────────

model EmailActivityLog {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @db.Uuid
  emailAccountId  String              @db.Uuid
  direction       String              // OUTBOUND | INBOUND
  status          String              // QUEUED | SENDING | SENT | FAILED | RETRYING | PERMANENT_FAILURE | RECEIVED | POLL_STARTED | POLL_COMPLETE | POLL_FAILED
  subject         String?
  fromAddress     String?
  toAddresses     String[]
  messageId       String?
  ticketId        String?             @db.Uuid
  attemptNumber   Int                 @default(1)
  errorCode       String?
  errorMessage    String?
  rawMeta         Json?
  occurredAt      DateTime            @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id])

  @@index([tenantId, emailAccountId])
  @@index([tenantId, status])
  @@index([tenantId, occurredAt])
  @@index([ticketId])
  @@map("email_activity_logs")
}

model EmailPollJob {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @db.Uuid
  emailAccountId        String    @unique @db.Uuid
  lastPollAt            DateTime?
  lastUid               Int?
  consecutiveFailures   Int       @default(0)
  nextPollAt            DateTime?
  isPaused              Boolean   @default(false)
  pauseReason           String?

  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id])

  @@index([tenantId])
  @@index([nextPollAt])
  @@map("email_poll_jobs")
}

model SchedulerJob {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String?  @db.Uuid
  jobType       String   // EMAIL_DELIVERY | IMAP_POLL | EMAIL_RETRY | SLA_CHECK | ESCALATION | AUTO_CLOSE
  status        String   @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | CANCELLED
  payload       Json?
  result        Json?
  errorMessage  String?
  attemptNumber Int      @default(1)
  maxAttempts   Int      @default(3)
  scheduledFor  DateTime @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([tenantId, jobType])
  @@map("scheduler_jobs")
}

// ─── Change Management ────────────────────────────────────────────────────────

// Model 19: Change
model Change {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid
  changeNumber       Int
  type               ChangeType   @default(NORMAL)
  title              String
  description        String?
  implementationPlan String?
  backoutPlan        String?
  testingPlan        String?
  riskLevel          RiskLevel    @default(MEDIUM)
  status             ChangeStatus @default(NEW)
  requestedById      String?      @db.Uuid
  assignedToId       String?      @db.Uuid
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  actualStart        DateTime?
  actualEnd          DateTime?
  closedAt           DateTime?
  customFields       Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  approvals           ChangeApproval[]
  activities          ChangeActivity[]
  changeApplications  ChangeApplication[]
  changeAssets        ChangeAsset[]
  cabMeetingChanges   CABMeetingChange[]

  @@unique([tenantId, changeNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scheduledStart])
  @@map("changes")
}

// Model 20: ChangeApproval
model ChangeApproval {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  changeId      String         @db.Uuid
  approverId    String         @db.Uuid
  status        ApprovalStatus @default(PENDING)
  sequenceOrder Int            @default(0)
  comments      String?
  decidedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  change   Change @relation(fields: [changeId], references: [id])
  approver User   @relation(fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([tenantId, changeId])
  @@index([tenantId, status])
  @@map("change_approvals")
}

// Model 21: ChangeActivity
model ChangeActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  changeId     String   @db.Uuid
  actorId      String?  @db.Uuid
  activityType String
  fieldName    String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  change Change @relation(fields: [changeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, changeId])
  @@map("change_activities")
}

// Model 22: ChangeApplication
model ChangeApplication {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  changeId      String   @db.Uuid
  applicationId String   @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  change      Change      @relation(fields: [changeId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@unique([changeId, applicationId])
  @@index([tenantId])
  @@map("change_applications")
}

// Model 23: ChangeAsset
model ChangeAsset {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  changeId  String   @db.Uuid
  assetId   String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  change Change @relation(fields: [changeId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@unique([changeId, assetId])
  @@index([tenantId])
  @@map("change_assets")
}

// Model 24: CABMeeting
model CABMeeting {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @db.Uuid
  title           String
  scheduledFor    DateTime
  durationMinutes Int              @default(60)
  location        String?
  meetingUrl      String?
  status          CABMeetingStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  attendees  CABMeetingAttendee[]
  changes    CABMeetingChange[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@map("cab_meetings")
}

// Model 25: CABMeetingAttendee
model CABMeetingAttendee {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @db.Uuid
  meetingId  String          @db.Uuid
  userId     String          @db.Uuid
