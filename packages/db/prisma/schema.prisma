  scopes         String[]
  maxEnrollments Int       @default(1)
  enrollCount    Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("agent_enrollment_tokens")
}

// Model 38: InventorySnapshot
model InventorySnapshot {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  agentId  String @db.Uuid

  // Identity
  hostname   String?
  fqdn       String?
  deviceType String?

  // OS
  operatingSystem String?
  osVersion       String?
  osBuild         String?
  osEdition       String?

  // CPU (quick-query fields)
  cpuModel    String?
  cpuCores    Int?
  cpuThreads  Int?
  cpuSpeedMhz Float?

  // Memory
  ramGb Float?

  // Hardware identity
  serialNumber      String?
  manufacturer      String?
  model             String?
  biosVersion       String?
  tpmVersion        String?
  secureBootEnabled Boolean?

  // Security posture (quick-query)
  diskEncrypted    Boolean?
  antivirusProduct String?
  firewallEnabled  Boolean?

  // Directory
  domainName String?

  // Virtualization
  isVirtual      Boolean?
  hypervisorType String?

  // Uptime
  lastBootTime  DateTime?
  uptimeSeconds Float?

  // Detailed JSON data (full collections)
  disks             Json?
  networkInterfaces Json?
  installedSoftware Json?
  services          Json?
  windowsUpdates    Json?
  memoryModules     Json?
  gpus              Json?
  battery           Json?
  monitors          Json?
  bitLockerVolumes  Json?
  securityPosture   Json?
  directoryStatus   Json?
  performance       Json?
  virtualization    Json?
  localUsers        Json?
  // Connected hardware (added in v1.0.0.6)
  printers          Json?
  usbDevices        Json?
  cameras           Json?
  biometricDevices  Json?
  smartCardReaders  Json?
  audioDevices      Json?
  // Compliance hardware
  tpmDetails        Json?
  vbsStatus         Json?
  rawData           Json?
  scanDurationMs    Float?

  collectedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, collectedAt])
  @@map("inventory_snapshots")
}

// Model 38.1: InventoryDiff — pre-computed diff between consecutive InventorySnapshot records
// fromSnapshotId / toSnapshotId are reference UUIDs only (no FK) so rows survive snapshot deletion
model InventoryDiff {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  agentId        String   @db.Uuid
  ciId           String?  @db.Uuid
  fromSnapshotId String?  @db.Uuid
  toSnapshotId   String?  @db.Uuid
  diffJson       Json
  collectedAt    DateTime
  createdAt      DateTime @default(now())

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent  Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ci     CmdbConfigurationItem? @relation(fields: [ciId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, agentId, collectedAt])
  @@index([tenantId, ciId, collectedAt])
  @@map("inventory_diffs")
}

// Model 39: MetricSample
model MetricSample {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  agentId    String   @db.Uuid
  metricType String
  metricName String
  value      Float
  unit       String?
  tags       Json?
  timestamp  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, timestamp])
  @@map("metric_samples")
}

