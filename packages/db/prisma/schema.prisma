}

// ─── Asset & Endpoint Management ─────────────────────────────────────────────

// Model 28: Site
model Site {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  name                 String
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?
  primaryContactName   String?
  primaryContactEmail  String?
  primaryContactPhone  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  users  User[]
  assets Asset[]

  @@index([tenantId])
  @@map("sites")
}

// Model 29: BusinessUnit
model BusinessUnit {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  code         String?
  managerName  String?
  managerEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("business_units")
}

// Model 30: Asset
model Asset {
  id                 String      @id @default(uuid()) @db.Uuid
  tenantId           String      @db.Uuid
  assetTag           String?
  serialNumber       String?
  manufacturer       String?
  model              String?
  status             AssetStatus @default(IN_STOCK)
  purchaseDate       DateTime?
  purchaseCost       Float?
  warrantyExpiry     DateTime?
  assignedToId       String?     @db.Uuid
  siteId             String?     @db.Uuid
  hostname           String?
  operatingSystem    String?
  osVersion          String?
  cpuModel           String?
  cpuCores           Int?
  ramGb              Float?
  disks              Json?
  networkInterfaces  Json?
  softwareInventory  Json?
  lastInventoryAt    DateTime?
  customFields       Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  site                Site?               @relation(fields: [siteId], references: [id])
  changeAssets        ChangeAsset[]
  applicationAssets   ApplicationAsset[]
  cmdbConfigItems     CmdbConfigurationItem[]
  contractAssets      ContractAsset[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("assets")
}

// ─── Application Portfolio ────────────────────────────────────────────────────

// Model 31: Application
model Application {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String            @db.Uuid
  name                String
  type                ApplicationType   @default(OTHER)
  status              ApplicationStatus @default(ACTIVE)
  criticality         CriticalityLevel  @default(MEDIUM)
  hostingModel        HostingModel      @default(ON_PREMISE)
  techStack           String[]
  authMethod          String?
  dataClassification  String?
  annualCost          Float?
  rpo                 Int?
  rto                 Int?
  lifecycleStage      LifecycleStage    @default(PRODUCTION)
  strategicRating     Int?
  description         String?
  customFields        Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  dependencies        ApplicationDependency[] @relation("SourceApp")
  dependents          ApplicationDependency[] @relation("TargetApp")
  documents           ApplicationDocument[]
  activities          ApplicationActivity[]
  applicationAssets   ApplicationAsset[]
  changeApplications  ChangeApplication[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("applications")
}

// Model 32: ApplicationDependency
model ApplicationDependency {
  id                    String         @id @default(uuid()) @db.Uuid
  tenantId              String         @db.Uuid
  sourceApplicationId   String         @db.Uuid
  targetApplicationId   String         @db.Uuid
  dependencyType        DependencyType @default(OTHER)
  description           String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  sourceApplication Application @relation("SourceApp", fields: [sourceApplicationId], references: [id])
  targetApplication Application @relation("TargetApp", fields: [targetApplicationId], references: [id])

  @@unique([sourceApplicationId, targetApplicationId])
  @@index([tenantId])
  @@map("application_dependencies")
}

// Model 33: ApplicationDocument
model ApplicationDocument {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  applicationId String       @db.Uuid
  title         String
  documentType  DocumentType @default(OTHER)
  url           String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, applicationId])
  @@map("application_documents")
}

// Model 34: ApplicationActivity
model ApplicationActivity {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  applicationId String   @db.Uuid
  actorId       String?  @db.Uuid
  activityType  String
  fieldName     String?
  oldValue      String?
  newValue      String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, applicationId])
  @@map("application_activities")
}

// Model 35: ApplicationAsset
model ApplicationAsset {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @db.Uuid
  applicationId    String               @db.Uuid
  assetId          String               @db.Uuid
  relationshipType AppAssetRelationship @default(RUNS_ON)
  isPrimary        Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  asset       Asset       @relation(fields: [assetId], references: [id])

  @@unique([applicationId, assetId])
  @@index([tenantId])
  @@map("application_assets")
}

// ─── Agent & Inventory ────────────────────────────────────────────────────────

// Model 36: Agent
model Agent {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  agentKey        String        @unique
  hostname        String
  platform        AgentPlatform
  platformVersion String?
  agentVersion    String?
  status          AgentStatus   @default(ENROLLING)
  lastHeartbeatAt DateTime?
  enrolledAt      DateTime?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  inventorySnapshots InventorySnapshot[]
  metricSamples      MetricSample[]
  cmdbConfigItems    CmdbConfigurationItem[]
  cmdbChangeRecords  CmdbChangeRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("agents")
}

// Model 37: AgentEnrollmentToken
model AgentEnrollmentToken {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tokenHash      String    @unique
  scopes         String[]
  maxEnrollments Int       @default(1)
  enrollCount    Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("agent_enrollment_tokens")
}

// Model 38: InventorySnapshot
model InventorySnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  agentId            String   @db.Uuid
  hostname           String?
  operatingSystem    String?
  osVersion          String?
  cpuModel           String?
  cpuCores           Int?
  ramGb              Float?
  disks              Json?
  networkInterfaces  Json?
  installedSoftware  Json?
  localUsers         Json?
  rawData            Json?
  collectedAt        DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, collectedAt])
  @@map("inventory_snapshots")
}

// Model 39: MetricSample
model MetricSample {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  agentId     String   @db.Uuid
  metricType  String
  metricName  String
  value       Float
  unit        String?
  tags        Json?
  timestamp   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, timestamp])
  @@map("metric_samples")
}

// ─── CMDB ─────────────────────────────────────────────────────────────────────

// Model 40: CmdbCategory
model CmdbCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  slug        String
  icon        String?
  color       String?
  parentId    String?  @db.Uuid
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  parent          CmdbCategory?           @relation("CmdbCategoryParent", fields: [parentId], references: [id])
  children        CmdbCategory[]          @relation("CmdbCategoryParent")
  configItems     CmdbConfigurationItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("cmdb_categories")
}

// Model 41: CmdbConfigurationItem
model CmdbConfigurationItem {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @db.Uuid
  ciNumber       Int
  name           String
  type           CmdbCiType        @default(OTHER)
  status         CmdbCiStatus      @default(ACTIVE)
  environment    CmdbCiEnvironment @default(PRODUCTION)
  categoryId     String?           @db.Uuid
  assetId        String?           @db.Uuid
  agentId        String?           @db.Uuid
  ownerId        String?           @db.Uuid
  siteId         String?           @db.Uuid
  attributesJson Json?
  discoveredAt   DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  category      CmdbCategory?      @relation(fields: [categoryId], references: [id])
  asset         Asset?             @relation(fields: [assetId], references: [id])
  agent         Agent?             @relation(fields: [agentId], references: [id])
  sourceRels    CmdbRelationship[] @relation("CmdbRelSource")
  targetRels    CmdbRelationship[] @relation("CmdbRelTarget")
  changeRecords CmdbChangeRecord[]
  ticketLinks   CmdbTicketLink[]

  @@unique([tenantId, ciNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@map("cmdb_configuration_items")
}

// Model 42: CmdbRelationship
model CmdbRelationship {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @db.Uuid
  sourceId         String               @db.Uuid
  targetId         String               @db.Uuid
  relationshipType CmdbRelationshipType
  description      String?
  isDiscovered     Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  source CmdbConfigurationItem @relation("CmdbRelSource", fields: [sourceId], references: [id])
  target CmdbConfigurationItem @relation("CmdbRelTarget", fields: [targetId], references: [id])

  @@unique([sourceId, targetId, relationshipType])
  @@index([tenantId])
  @@index([tenantId, sourceId])
  @@index([tenantId, targetId])
  @@map("cmdb_relationships")
}

// Model 43: CmdbChangeRecord
model CmdbChangeRecord {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @db.Uuid
  ciId       String         @db.Uuid
  changeType CmdbChangeType
  fieldName  String?
  oldValue   String?
  newValue   String?
  changedBy  CmdbChangedBy
  agentId    String?        @db.Uuid
  userId     String?        @db.Uuid
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  ci     CmdbConfigurationItem @relation(fields: [ciId], references: [id])
  agent  Agent?                @relation(fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ciId])
  @@index([tenantId, createdAt])
  @@map("cmdb_change_records")
}

// Model 44: CmdbTicketLink
model CmdbTicketLink {
  id       String             @id @default(uuid()) @db.Uuid
  tenantId String             @db.Uuid
  ciId     String             @db.Uuid
  ticketId String             @db.Uuid
  linkType CmdbTicketLinkType @default(AFFECTED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
