  tenantId     String   @db.Uuid
  snapshotDate DateTime
  activeUsers  Int      @default(0)
  activeAgents Int      @default(0)
  ticketCount  Int      @default(0)
  storageBytes BigInt   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotDate])
  @@index([tenantId])
  @@map("tenant_usage_snapshots")
}

// Model 50: OwnerNote (GLOBAL)
model OwnerNote {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  ownerUserId String   @db.Uuid
  content     String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  ownerUser OwnerUser @relation(fields: [ownerUserId], references: [id])

