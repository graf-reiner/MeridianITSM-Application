  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  ASSIGN
  ESCALATE
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum CmdbCiStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
  PLANNED
}

enum CmdbCiType {
  SERVER
  WORKSTATION
  NETWORK_DEVICE
  SOFTWARE
  SERVICE
  DATABASE
  VIRTUAL_MACHINE
  CONTAINER
  OTHER
}

enum CmdbCiEnvironment {
  PRODUCTION
  STAGING
  DEV
  DR
}

enum CmdbRelationshipType {
  DEPENDS_ON
  HOSTS
  CONNECTS_TO
  RUNS_ON
  BACKS_UP
  VIRTUALIZES
  MEMBER_OF
}

enum CmdbChangeType {
  CREATED
