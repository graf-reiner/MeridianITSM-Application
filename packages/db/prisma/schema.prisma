  // Governance & Discovery
  installDate        DateTime?
  firstDiscoveredAt  DateTime?
  lastVerifiedAt     DateTime?
  sourceSystem       String?
  sourceRecordKey    String?
  sourceOfTruth      Boolean   @default(false)
  reconciliationRank Int       @default(100)
  isDeleted          Boolean   @default(false)

  // Flexible attributes (for tenant-specific custom data)
  attributesJson Json?
  discoveredAt   DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  category          CmdbCategory?    @relation(fields: [categoryId], references: [id])
  asset             Asset?           @relation(fields: [assetId], references: [id])
  agent             Agent?           @relation(fields: [agentId], references: [id])
  ciClass           CmdbCiClass?     @relation(fields: [classId], references: [id])
  lifecycleStatus   CmdbStatus?      @relation("CmdbCiLifecycleStatus", fields: [lifecycleStatusId], references: [id])
  operationalStatus CmdbStatus?      @relation("CmdbCiOperationalStatus", fields: [operationalStatusId], references: [id])
  cmdbEnvironment   CmdbEnvironment? @relation(fields: [environmentId], references: [id])
  manufacturer      CmdbVendor?      @relation(fields: [manufacturerId], references: [id])
  supportGroup      UserGroup?       @relation("CmdbCiSupportGroup", fields: [supportGroupId], references: [id])
  businessOwner     User?            @relation("CmdbCiBusinessOwner", fields: [businessOwnerId], references: [id])
  technicalOwner    User?            @relation("CmdbCiTechnicalOwner", fields: [technicalOwnerId], references: [id])

  sourceRels    CmdbRelationship[] @relation("CmdbRelSource")
  targetRels    CmdbRelationship[] @relation("CmdbRelTarget")
  changeRecords CmdbChangeRecord[]
  ticketLinks   CmdbTicketLink[]

  // Extension tables (1:1)
  serverExt        CmdbCiServer?
  applicationExt   CmdbCiApplication?
  databaseExt      CmdbCiDatabase?
  networkDeviceExt CmdbCiNetworkDevice?
  cloudResourceExt CmdbCiCloudResource?
  endpointExt      CmdbCiEndpoint?
  serviceExt       CmdbService?

  // ITSM links
  cmdbChangeLinks   CmdbChangeLink[]
  cmdbIncidentLinks CmdbIncidentLink[]
  cmdbProblemLinks  CmdbProblemLink[]

  // Governance
  attestations         CmdbAttestation[]
  duplicateCandidates1 CmdbDuplicateCandidate[] @relation("CmdbDupCi1")
  duplicateCandidates2 CmdbDuplicateCandidate[] @relation("CmdbDupCi2")

  // Server extension reverse (hypervisor host)
  hostedVMs CmdbCiServer[] @relation("CmdbHypervisorHost")

  @@unique([tenantId, ciNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, classId])
  @@index([tenantId, lifecycleStatusId])
  @@index([tenantId, environmentId])
  @@index([tenantId, hostname])
  @@index([tenantId, fqdn])
  @@index([tenantId, externalId])
  @@index([tenantId, serialNumber])
  @@index([tenantId, assetTag])
  @@index([tenantId, supportGroupId])
  @@index([tenantId, businessOwnerId])
  @@index([tenantId, technicalOwnerId])
  @@index([tenantId, manufacturerId])
  @@index([tenantId, createdAt])
  @@map("cmdb_configuration_items")
}

// Model 47: CmdbRelationship
