// ─── Agent & Inventory ────────────────────────────────────────────────────────

// Model 36: Agent
model Agent {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @db.Uuid
  agentKey         String        @unique
  hostname         String
  platform         AgentPlatform
  platformVersion  String?
  agentVersion     String?
  status           AgentStatus   @default(ENROLLING)
  lastHeartbeatAt  DateTime?
  enrolledAt       DateTime?
  lastReconciledAt DateTime?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id])
  inventorySnapshots InventorySnapshot[]
  inventoryDiffs     InventoryDiff[]
  metricSamples      MetricSample[]
  cmdbConfigItems    CmdbConfigurationItem[]
  cmdbChangeRecords  CmdbChangeRecord[]
  deploymentTargets  AgentUpdateDeploymentTarget[]
  eventLogs          AgentEventLog[]

  forceUpdateUrl   String?
  updateInProgress Boolean   @default(false)
  updateStartedAt  DateTime?

  installFormat AgentUpdateFormat?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("agents")
}

model AgentUpdate {
  id           String            @id @default(uuid()) @db.Uuid
  version      String
  platform     AgentPlatform
  format       AgentUpdateFormat
  downloadUrl  String
  checksum     String
  fileSize     Int
  releaseNotes String?
  storageKey   String?
  uploadedBy   String?           @db.Uuid
  createdAt    DateTime          @default(now())

  deployments AgentUpdateDeployment[]

  @@unique([version, platform, format])
  @@map("agent_updates")
}

// Model 37.5: AgentUpdateDeployment — one row per deploy action
model AgentUpdateDeployment {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @db.Uuid
  agentUpdateId    String        @db.Uuid
  triggeredById    String?       @db.Uuid
  targetKind       String // "ALL" | "SINGLE" | "SELECTION"
  platform         AgentPlatform
  targetCount      Int           @default(0)
  successCount     Int           @default(0)
  errorCount       Int           @default(0)
  pendingCount     Int           @default(0)
  changeId         String?       @unique @db.Uuid
  awaitingApproval Boolean       @default(false)
  createdAt        DateTime      @default(now())

  tenant      Tenant                        @relation(fields: [tenantId], references: [id])
  agentUpdate AgentUpdate                   @relation(fields: [agentUpdateId], references: [id])
  triggeredBy User?                         @relation("UserTriggeredAgentDeployments", fields: [triggeredById], references: [id])
  change      Change?                       @relation(fields: [changeId], references: [id])
  targets     AgentUpdateDeploymentTarget[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("agent_update_deployments")
}

// Model 37.6: per-agent deployment result
model AgentUpdateDeploymentTarget {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  deploymentId String    @db.Uuid
  agentId      String    @db.Uuid
  fromVersion  String?
  toVersion    String
  status       String    @default("PENDING") // PENDING | DOWNLOADING | INSTALLING | SUCCESS | ERROR
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  deployment AgentUpdateDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  agent      Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, deploymentId])
  @@index([tenantId, agentId])
  @@map("agent_update_deployment_targets")
}

// Model 37.7: agent-emitted event log
model AgentEventLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  agentId   String   @db.Uuid
  level     String // INFO | WARN | ERROR
  category  String?
  message   String
  context   Json?
  eventAt   DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, agentId, createdAt])
  @@index([tenantId, level])
  @@map("agent_event_logs")
}

// Model 37: AgentEnrollmentToken
model AgentEnrollmentToken {
