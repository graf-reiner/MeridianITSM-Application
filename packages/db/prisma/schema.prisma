// Model 30: Asset
model Asset {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  assetTag       String?
  serialNumber   String?
  manufacturer   String?
  model          String?
  status         AssetStatus @default(IN_STOCK)
  purchaseDate   DateTime?
  purchaseCost   Float?
  warrantyExpiry DateTime?
  assignedToId   String?     @db.Uuid
  siteId         String?     @db.Uuid
  // Phase 8 Wave 5 (CASR-01): hardware/OS/software fields moved to
  //   CmdbCiServer (hostname, operatingSystem, osVersion, cpuModel, cpuCount,
  //     memoryGb, disksJson, networkInterfacesJson)
  //   CmdbSoftwareInstalled (softwareInventory — normalized per-row)
  //   CmdbCiServer.lastSeenAt / agent heartbeat (lastInventoryAt)
  // To resolve for an Asset, JOIN cmdb_configuration_items ci ON ci.assetId = assets.id
  // then JOIN cmdb_ci_servers or cmdb_software_installed as needed.
  customFields   Json?
  notes          String?
  assetTypeId    String?     @db.Uuid
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant            Tenant                  @relation(fields: [tenantId], references: [id])
  site              Site?                   @relation(fields: [siteId], references: [id])
  assetType         AssetType?              @relation(fields: [assetTypeId], references: [id])
  changeAssets      ChangeAsset[]
  applicationAssets ApplicationAsset[]
  cmdbConfigItems   CmdbConfigurationItem[]
  contractAssets    ContractAsset[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("assets")
}

// ─── Application Portfolio ────────────────────────────────────────────────────

// Model 31: Application
model Application {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @db.Uuid
  name               String
  type               ApplicationType   @default(OTHER)
  status             ApplicationStatus @default(ACTIVE)
  criticality        CriticalityLevel  @default(MEDIUM)
  hostingModel       HostingModel      @default(ON_PREMISE)
  techStack          String[]
  authMethod         String?
  dataClassification String?
  annualCost         Float?
  rpo                Int?
  rto                Int?
  lifecycleStage     LifecycleStage    @default(PRODUCTION)
  strategicRating    Int?
  description        String?
  customFields       Json?

  // APM ↔ CMDB bridge — primary CI is the canonical CmdbConfigurationItem
  // for this Application (class = application_instance). Auto-created on
  // Application save; nullable for backfill + ON DELETE SET NULL safety.
  primaryCiId String? @db.Uuid

  // APM-only portfolio fields (don't belong in CMDB — they describe the
  // application contract, not the deployed infrastructure)
  supportNotes   String? // narrative runbook content
  specialNotes   String? // operational quirks ("Win10+ only")
  osRequirements String? // declared platform requirements
  vendorContact  String? // vendor support phone/email
  licenseInfo    String? // plain text; full ApplicationLicense model is a future milestone

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  primaryCi          CmdbConfigurationItem?  @relation("ApplicationPrimaryCi", fields: [primaryCiId], references: [id], onDelete: SetNull)
  dependencies       ApplicationDependency[] @relation("SourceApp")
  dependents         ApplicationDependency[] @relation("TargetApp")
  documents          ApplicationDocument[]
  activities         ApplicationActivity[]
  applicationAssets  ApplicationAsset[]
  changeApplications ChangeApplication[]
  cmdbCiApplications CmdbCiApplication[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, primaryCiId])
  @@map("applications")
}

// Model 32: ApplicationDependency
model ApplicationDependency {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @db.Uuid
  sourceApplicationId String         @db.Uuid
  targetApplicationId String         @db.Uuid
  dependencyType      DependencyType @default(OTHER)
  description         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  sourceApplication Application @relation("SourceApp", fields: [sourceApplicationId], references: [id])
  targetApplication Application @relation("TargetApp", fields: [targetApplicationId], references: [id])

  @@unique([sourceApplicationId, targetApplicationId])
  @@index([tenantId])
  @@map("application_dependencies")
}

// Model 33: ApplicationDocument
model ApplicationDocument {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  applicationId String       @db.Uuid
  title         String
  documentType  DocumentType @default(OTHER)
