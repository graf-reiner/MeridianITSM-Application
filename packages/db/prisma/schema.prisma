// ─── Workflow Automation Engine ────────────────────────────────────────────────

model Workflow {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  name             String
  description      String?
  status           String   @default("DRAFT") // DRAFT | PUBLISHED | DISABLED
  trigger          String // Same trigger strings as NotificationRule
  scopedQueueId    String?  @db.Uuid
  currentVersionId String?  @db.Uuid
  createdById      String?  @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  queue      Queue?              @relation("WorkflowQueue", fields: [scopedQueueId], references: [id])
  versions   WorkflowVersion[]
  executions WorkflowExecution[]
  auditLogs  WorkflowAuditLog[]

  @@index([tenantId, trigger, status])
  @@index([tenantId])
  @@map("workflows")
}

model WorkflowVersion {
  id          String   @id @default(uuid()) @db.Uuid
  workflowId  String   @db.Uuid
  version     Int      @default(1)
  graphJson   Json     @default("{\"nodes\":[],\"edges\":[]}")
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())

  workflow   Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("workflow_versions")
}

model WorkflowExecution {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  workflowId   String    @db.Uuid
  versionId    String    @db.Uuid
  trigger      String
  status       String    @default("RUNNING") // RUNNING | COMPLETED | FAILED | SKIPPED
  eventPayload Json?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  error        String?
  isSimulation Boolean   @default(false)

  tenant   Tenant                  @relation(fields: [tenantId], references: [id])
  workflow Workflow                @relation(fields: [workflowId], references: [id])
  version  WorkflowVersion         @relation(fields: [versionId], references: [id])
  steps    WorkflowExecutionStep[]

  @@index([tenantId, startedAt])
  @@index([workflowId, startedAt])
  @@map("workflow_executions")
}

model WorkflowExecutionStep {
  id          String    @id @default(uuid()) @db.Uuid
  executionId String    @db.Uuid
  nodeId      String // React Flow node ID within graph
  nodeType    String
  status      String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | SKIPPED
  inputData   Json?
  outputData  Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("workflow_execution_steps")
}

model WorkflowAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  workflowId String   @db.Uuid
  action     String // CREATED | UPDATED | PUBLISHED | DISABLED | DELETED | VERSION_CREATED
  actorId    String?  @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([workflowId])
  @@map("workflow_audit_logs")
}

// ─── Custom Forms ───────────────────────────────────────────────────────────

enum FieldDefinitionStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum CustomFormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Model 96: FieldDefinition — Reusable field library for custom forms
model FieldDefinition {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @db.Uuid
  key              String // Tenant-unique slug (e.g., "employee_name")
  label            String
  fieldType        String // text, textarea, richtext, number, select, multiselect, radio, checkbox, date, datetime, email, phone, url, file, user_picker, group_picker, hidden
  description      String?
  placeholder      String?
  helpText         String?
  isRequired       Boolean               @default(false)
  isReadOnly       Boolean               @default(false)
  validationConfig Json? // { minLength, maxLength, min, max, pattern }
  optionsJson      Json? // [{ label, value }] for select/multiselect/radio
  status           FieldDefinitionStatus @default(ACTIVE)
  version          Int                   @default(1)
  createdById      String                @db.Uuid
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation("FieldDefinitionCreatedBy", fields: [createdById], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId, status])
  @@map("field_definitions")
}

// Model 97: CustomForm — Form definitions with layout, mapping, and conditions
model CustomForm {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @db.Uuid
  name                String
  slug                String // Tenant-unique URL-friendly identifier
  description         String?
  icon                String? // MDI icon path
  color               String? // Accent color hex
  status              CustomFormStatus @default(DRAFT)
  currentVersion      Int              @default(1)
  layoutJson          Json // { sections: [{ id, title, position, fields: [{ id, fieldDefinitionId, position, overrides }] }] }
  mappingJson         Json             @default("{}") // { title?: fieldInstanceId, description?: fieldInstanceId, priority?: fieldInstanceId, ... }
  conditionsJson      Json             @default("[]") // [{ id, targetFieldId, parentFieldId, operator, value, action }]
  ticketType          TicketType       @default(SERVICE_REQUEST)
  defaultPriority     TicketPriority?
  defaultCategoryId   String?          @db.Uuid
  defaultQueueId      String?          @db.Uuid
  defaultAssigneeId   String?          @db.Uuid
  defaultGroupId      String?          @db.Uuid
  defaultSlaId        String?          @db.Uuid
  defaultTags         String[]
  titleTemplate       String? // "{{field_key}} request for {{another_field}}"
  descriptionTemplate String?          @db.Text
  showInPortal        Boolean          @default(true)
  requireAuth         Boolean          @default(true)
  position            Int              @default(0)
  createdById         String           @db.Uuid
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  createdBy   User                   @relation("CustomFormCreatedBy", fields: [createdById], references: [id])
  submissions CustomFormSubmission[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("custom_forms")
}

// Model 98: CustomFormSubmission — Submission audit trail with ticket linkage
model CustomFormSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  formId         String   @db.Uuid
  formVersion    Int // Snapshot of which version was used
  ticketId       String?  @db.Uuid
  submittedById  String   @db.Uuid
  valuesJson     Json // Raw submitted field values
  layoutSnapshot Json? // Copy of layoutJson at submission time
  status         String   @default("COMPLETED") // COMPLETED | FAILED
  errorMessage   String?
  createdAt      DateTime @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  form        CustomForm @relation(fields: [formId], references: [id])
  ticket      Ticket?    @relation(fields: [ticketId], references: [id])
  submittedBy User       @relation("CustomFormSubmittedBy", fields: [submittedById], references: [id])

  @@index([tenantId, formId])
  @@index([tenantId, submittedById])
  @@map("custom_form_submissions")
}

