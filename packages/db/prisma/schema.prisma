generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantType {
  MSP
  ENTERPRISE
  B2C
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionPlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
