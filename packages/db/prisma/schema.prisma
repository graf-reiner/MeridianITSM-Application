  rsvpStatus RSVPStatus      @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id])
  meeting CABMeeting @relation(fields: [meetingId], references: [id])
  user    User       @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([tenantId])
  @@map("cab_meeting_attendees")
}

// Model 26: CABMeetingChange
model CABMeetingChange {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  meetingId    String      @db.Uuid
  changeId     String      @db.Uuid
  agendaOrder  Int         @default(0)
  outcome      CABOutcome?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id])
  meeting CABMeeting @relation(fields: [meetingId], references: [id])
  change  Change     @relation(fields: [changeId], references: [id])

  @@unique([meetingId, changeId])
  @@index([tenantId])
  @@map("cab_meeting_changes")
}

// ─── Knowledge Management ─────────────────────────────────────────────────────

// Model 27: KnowledgeArticle
model KnowledgeArticle {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  articleNumber Int
  title         String
  summary       String?
  content       String
  tags          String[]
  visibility    ArticleVisibility @default(INTERNAL)
  status        ArticleStatus     @default(DRAFT)
