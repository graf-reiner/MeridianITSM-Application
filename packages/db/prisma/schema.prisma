}

enum DocumentType {
  ARCHITECTURE
  API_SPEC
  RUNBOOK
  SLA_DOC
  SECURITY
  COMPLIANCE
  USER_GUIDE
  ADMIN_GUIDE
  RELEASE_NOTES
  DEPLOYMENT
  OTHER
}

enum AppAssetRelationship {
  RUNS_ON
  HOSTED_BY
  USES
}

enum WebhookEventType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_RESOLVED
  TICKET_CLOSED
  COMMENT_ADDED
  CHANGE_CREATED
  CHANGE_APPROVED
  SLA_BREACH
}

enum AlertChannelType {
  EMAIL
  SMS
  SLACK
  TEAMS
  DISCORD
  TELEGRAM
}

// ─── Core Tenancy & Identity ──────────────────────────────────────────────────

// Model 1: Tenant (GLOBAL — no tenantId)
model Tenant {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  slug           String               @unique
  type           TenantType           @default(MSP)
  status         TenantStatus         @default(ACTIVE)
  subdomain      String?              @unique
  backendUrl     String?
  settings       Json?
  plan           SubscriptionPlanTier @default(STARTER)
  planLimitsJson Json?
  maxUsers       Int                  @default(5)
  maxAgents      Int                  @default(0)
  maxSites       Int                  @default(1)
  trialEndsAt    DateTime?
  suspendedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  agentUpdatePolicy         String  @default("manual")
  agentUpdateWindowStart    String?
  agentUpdateWindowEnd      String?
  agentUpdateWindowDay      String?
  agentDeployRequiresChange Boolean @default(false)

  inventoryIntervalMinutes    Int @default(240)
  heartbeatIntervalSeconds    Int @default(300)
  changeRetentionDays         Int @default(90)
  snapshotRetentionCount      Int @default(30)
  inventoryMinIntervalMinutes Int @default(30)

  // Relations
  users                        User[]
  customerOrganizations        CustomerOrganization[]
  userGroups                   UserGroup[]
  roles                        Role[]
  userRoles                    UserRole[]
  sessions                     Session[]
  apiKeys                      ApiKey[]
  tickets                      Ticket[]
  ticketComments               TicketComment[]
  ticketAttachments            TicketAttachment[]
  ticketActivities             TicketActivity[]
  queues                       Queue[]
  slas                         SLA[]
  categories                   Category[]
  emailAccounts                EmailAccount[]
  changes                      Change[]
  changeApprovals              ChangeApproval[]
  changeActivities             ChangeActivity[]
  cabMeetings                  CABMeeting[]
  cabMeetingAttendees          CABMeetingAttendee[]
  cabMeetingChanges            CABMeetingChange[]
  knowledgeArticles            KnowledgeArticle[]
  assets                       Asset[]
  assetTypes                   AssetType[]
  sites                        Site[]
  businessUnits                BusinessUnit[]
  applications                 Application[]
  applicationActivities        ApplicationActivity[]
  applicationDependencies      ApplicationDependency[]
  applicationDocuments         ApplicationDocument[]
  applicationAssets            ApplicationAsset[]
  agents                       Agent[]
  agentEnrollmentTokens        AgentEnrollmentToken[]
  agentUpdateDeployments       AgentUpdateDeployment[]
  agentUpdateDeploymentTargets AgentUpdateDeploymentTarget[]
  agentEventLogs               AgentEventLog[]
  inventorySnapshots           InventorySnapshot[]
  metricSamples                MetricSample[]
  cmdbCiClasses                CmdbCiClass[]
  cmdbStatuses                 CmdbStatus[]
  cmdbEnvironments             CmdbEnvironment[]
  cmdbRelationshipTypeRefs     CmdbRelationshipTypeRef[]
  cmdbVendors                  CmdbVendor[]
  cmdbCategories               CmdbCategory[]
  cmdbConfigItems              CmdbConfigurationItem[]
  cmdbRelationships            CmdbRelationship[]
  cmdbChangeRecords            CmdbChangeRecord[]
  cmdbTicketLinks              CmdbTicketLink[]
  cmdbChangeLinks              CmdbChangeLink[]
  cmdbIncidentLinks            CmdbIncidentLink[]
  cmdbProblemLinks             CmdbProblemLink[]
  incidentProblemLinks         IncidentProblemLink[]
  chatBotSessions              ChatBotSession[]
  cmdbAttestations             CmdbAttestation[]
  cmdbDuplicateCandidates      CmdbDuplicateCandidate[]
  changeApplications           ChangeApplication[]
  changeAssets                 ChangeAsset[]
  contractAssets               ContractAsset[]
  ticketKnowledgeArticles      TicketKnowledgeArticle[]
  vendors                      Vendor[]
  contracts                    Contract[]
  auditLogs                    AuditLog[]
  notifications                Notification[]
  deviceTokens                 DeviceToken[]
  emailTemplates               EmailTemplate[]
  alertConfigurations          AlertConfiguration[]
  notificationRules            NotificationRule[]
  notificationRuleLogs         NotificationRuleLog[]
  scheduledReports             ScheduledReport[]
  webhooks                     Webhook[]
  webhookDeliveries            WebhookDelivery[]
  passwordResetTokens          PasswordResetToken[]
  userGroupMembers             UserGroupMember[]
  subscription                 TenantSubscription?
  usageSnapshots               TenantUsageSnapshot[]
  ownerNotes                   OwnerNote[]
  tags                         Tag[]
  ssoConnections               SsoConnection[]
  tenantAuthSettings           TenantAuthSettings?
  mfaTrustedDevices            MfaTrustedDevice[]
  emailActivityLogs            EmailActivityLog[]
  chatConversations            ChatConversation[]
  documentContents             DocumentContent[]
  cannedResponses              CannedResponse[]
  ticketWatchers               TicketWatcher[]
  savedTicketViews             SavedTicketView[]
  ticketLinks                  TicketLink[]
  surveyTemplates              SurveyTemplate[]
  surveyResponses              SurveyResponse[]
  escalationPolicies           EscalationPolicy[]
  ticketApprovalRules          TicketApprovalRule[]
  ticketApprovals              TicketApproval[]
  recurringTickets             RecurringTicket[]
  ticketTemplates              TicketTemplate[]
  ticketViewAssignments        TicketViewAssignment[]
  workflows                    Workflow[]
  workflowExecutions           WorkflowExecution[]
  workflowAuditLogs            WorkflowAuditLog[]
  fieldDefinitions             FieldDefinition[]
  customForms                  CustomForm[]
  customFormSubmissions        CustomFormSubmission[]
  changeTemplates              ChangeTemplate[]
  cmdbBaselines                CmdbBaseline[]
  holidays                     Holiday[]
  notificationTemplates        NotificationTemplate[]

  // Phase 8: installed software + migration audit
  cmdbSoftwareInstalled CmdbSoftwareInstalled[]
  cmdbMigrationAudit    CmdbMigrationAudit[]

  inventoryDiffs InventoryDiff[]

  @@map("tenants")
}

// Model 2: CustomerOrganization
model CustomerOrganization {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  name                String
  slug                String
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  address             String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("customer_organizations")
}

// Model 3: User
model User {
  id                      String     @id @default(uuid()) @db.Uuid
  tenantId                String     @db.Uuid
  email                   String
  passwordHash            String
  firstName               String
  lastName                String
  displayName             String?
  phone                   String?
  jobTitle                String?
  department              String?
  status                  UserStatus @default(ACTIVE)
  notificationPreferences Json?
  pushPreferences         Json?
  themePreference         String     @default("system")
  dashboardConfig         Json?
  siteId                  String?    @db.Uuid
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  tenant                       Tenant                  @relation(fields: [tenantId], references: [id])
  site                         Site?                   @relation(fields: [siteId], references: [id])
  userRoles                    UserRole[]
  sessions                     Session[]
  assignedTickets              Ticket[]                @relation("AssignedTo")
  requestedTickets             Ticket[]                @relation("RequestedBy")
  ticketComments               TicketComment[]
  ticketAttachments            TicketAttachment[]
  cabMeetingAttendees          CABMeetingAttendee[]
  changeApprovals              ChangeApproval[]
  notifications                Notification[]
  deviceTokens                 DeviceToken[]
  auditLogs                    AuditLog[]
  ticketActivities             TicketActivity[]        @relation("TicketActivityActor")
  passwordResetTokens          PasswordResetToken[]
  userGroupMembers             UserGroupMember[]
  apiKeys                      ApiKey[]
  federatedIdentities          FederatedIdentity[]
  mfaDevices                   MfaDevice[]
  mfaChallenges                MfaChallenge[]
  recoveryCodes                RecoveryCode[]
  mfaTrustedDevices            MfaTrustedDevice[]
  cmdbCisAsBusinessOwner       CmdbConfigurationItem[] @relation("CmdbCiBusinessOwner")
  cmdbCisAsTechnicalOwner      CmdbConfigurationItem[] @relation("CmdbCiTechnicalOwner")
  chatConversations            ChatConversation[]
  cannedResponses              CannedResponse[]        @relation("CannedResponseCreatedBy")
  ticketWatches                TicketWatcher[]
  savedTicketViews             SavedTicketView[]
  ticketLinksCreated           TicketLink[]            @relation("TicketLinkCreatedBy")
  surveyResponses              SurveyResponse[]
  ticketApprovalsGiven         TicketApproval[]        @relation("TicketApprovalApprover")
  recurringTicketsCreated      RecurringTicket[]       @relation("RecurringTicketCreatedBy")
  ticketTemplatesCreated       TicketTemplate[]        @relation("TicketTemplateCreatedBy")
  ticketViewAssignments        TicketViewAssignment[]  @relation("TicketViewAssignmentUser")
  fieldDefinitionsCreated      FieldDefinition[]       @relation("FieldDefinitionCreatedBy")
  customFormsCreated           CustomForm[]            @relation("CustomFormCreatedBy")
  customFormSubmissions        CustomFormSubmission[]  @relation("CustomFormSubmittedBy")
  majorIncidentCoordinations   Ticket[]                @relation("MajorIncidentCoordinator")
  notificationTemplatesCreated NotificationTemplate[]  @relation("NotificationTemplateCreatedBy")
  triggeredAgentDeployments    AgentUpdateDeployment[] @relation("UserTriggeredAgentDeployments")
  knowledgeArticlesAuthored    KnowledgeArticle[]      @relation("KnowledgeArticleAuthor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("users")
}

// Model 4: UserGroup
model UserGroup {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  email       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  isCmdbSupportGroup Boolean @default(false)

  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  userGroupMembers      UserGroupMember[]
  categories            Category[]
  queues                Queue[]
  ticketsAssigned       Ticket[]                @relation("TicketAssignedGroup")
  cmdbCisBySupport      CmdbConfigurationItem[] @relation("CmdbCiSupportGroup")
  cannedResponses       CannedResponse[]
  ticketViewAssignments TicketViewAssignment[]

  @@index([tenantId])
  @@map("user_groups")
}

// Model 5: UserGroupMember (extra join table)
model UserGroupMember {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  userGroupId String   @db.Uuid
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userGroup UserGroup @relation(fields: [userGroupId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userGroupId, userId])
  @@index([tenantId])
  @@map("user_group_members")
}

// Model 6: Role
model Role {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  slug         String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

// Model 7: UserRole
model UserRole {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @db.Uuid
  userId                 String   @db.Uuid
  roleId                 String   @db.Uuid
  customerOrganizationId String?  @db.Uuid
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
  role                 Role                  @relation(fields: [roleId], references: [id])
  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id])

  @@unique([userId, roleId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("user_roles")
}

// Model 8: Session
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  userId       String   @db.Uuid
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("sessions")
}

// Model 9: ApiKey
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  userId     String    @db.Uuid
  name       String
  keyHash    String
  keyPrefix  String
  scopes     Json
  rateLimit  Int       @default(100)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── Service Desk ─────────────────────────────────────────────────────────────

// Model 10: Ticket
model Ticket {
  id                         String         @id @default(uuid()) @db.Uuid
  tenantId                   String         @db.Uuid
  ticketNumber               Int
  type                       TicketType     @default(INCIDENT)
  title                      String
  description                String?
  priority                   TicketPriority @default(MEDIUM)
  impact                     TicketImpact?
  urgency                    TicketUrgency?
  status                     TicketStatus   @default(NEW)
  assignedToId               String?        @db.Uuid
  assignedGroupId            String?        @db.Uuid
  requestedById              String?        @db.Uuid
  queueId                    String?        @db.Uuid
  slaId                      String?        @db.Uuid
  categoryId                 String?        @db.Uuid
  slaBreachAt                DateTime?
  slaResponseAt              DateTime?
  firstResponseAt            DateTime?
  resolvedAt                 DateTime?
  closedAt                   DateTime?
  resolution                 String?
  tags                       String[]
  customFields               Json?
  parentId                   String?        @db.Uuid // Parent ticket for sub-task hierarchy
  mergedIntoId               String?        @db.Uuid // If merged, points to the target ticket
  rootCause                  String? // Problem management: root cause analysis (type=PROBLEM)
  workaround                 String? // Problem management: known workaround (type=PROBLEM)
  knowledgeArticleId         String?        @db.Uuid // Problem management: link to known error KB article
  isMajorIncident            Boolean        @default(false)
  majorIncidentCoordinatorId String?        @db.Uuid
  source                     String         @default("PORTAL")
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  tenant                   Tenant                   @relation(fields: [tenantId], references: [id])
  assignedTo               User?                    @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedGroup            UserGroup?               @relation("TicketAssignedGroup", fields: [assignedGroupId], references: [id])
  requestedBy              User?                    @relation("RequestedBy", fields: [requestedById], references: [id])
  queue                    Queue?                   @relation(fields: [queueId], references: [id])
  sla                      SLA?                     @relation(fields: [slaId], references: [id])
  category                 Category?                @relation(fields: [categoryId], references: [id])
  parent                   Ticket?                  @relation("TicketParentChild", fields: [parentId], references: [id])
  children                 Ticket[]                 @relation("TicketParentChild")
  mergedInto               Ticket?                  @relation("TicketMerge", fields: [mergedIntoId], references: [id])
  mergedFrom               Ticket[]                 @relation("TicketMerge")
  knowledgeArticle         KnowledgeArticle?        @relation("ProblemKnownError", fields: [knowledgeArticleId], references: [id])
  majorIncidentCoordinator User?                    @relation("MajorIncidentCoordinator", fields: [majorIncidentCoordinatorId], references: [id])
  comments                 TicketComment[]
  attachments              TicketAttachment[]
  activities               TicketActivity[]
  knowledgeArticles        TicketKnowledgeArticle[]
  cmdbTicketLinks          CmdbTicketLink[]
  cmdbIncidentLinks        CmdbIncidentLink[]
  cmdbProblemLinks         CmdbProblemLink[]
  watchers                 TicketWatcher[]
  linksFrom                TicketLink[]             @relation("TicketLinkFrom")
  linksTo                  TicketLink[]             @relation("TicketLinkTo")
  surveyResponse           SurveyResponse?
  approvals                TicketApproval[]
  customFormSubmissions    CustomFormSubmission[]
  incidentProblems         IncidentProblemLink[]    @relation("IncidentProblems") // When this ticket is an incident linked to problems
  problemIncidents         IncidentProblemLink[]    @relation("ProblemIncidents") // When this ticket is a problem with linked incidents

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, assignedToId])
  @@index([tenantId, createdAt])
  @@index([tenantId, slaBreachAt])
  @@index([tenantId, parentId])
  @@map("tickets")
}

// Model 11: TicketComment
model TicketComment {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  ticketId         String            @db.Uuid
  authorId         String            @db.Uuid
  content          String
  visibility       CommentVisibility @default(PUBLIC)
  timeSpentMinutes Int?
  ccUserIds        String[]          @default([]) @db.Uuid // One-time CC recipients for this comment
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_comments")
}

// Model 12: TicketAttachment
model TicketAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  ticketId     String   @db.Uuid
  uploadedById String   @db.Uuid
  filename     String
  mimeType     String
  fileSize     Int
  storagePath  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  ticket     Ticket @relation(fields: [ticketId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

// Model 13: TicketActivity
model TicketActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  ticketId     String   @db.Uuid
  actorId      String?  @db.Uuid
  activityType String
  fieldName    String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
  actor  User?  @relation("TicketActivityActor", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@index([tenantId, createdAt])
  @@map("ticket_activities")
}

// Ticket Watchers — users who receive notifications on all ticket updates
model TicketWatcher {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  ticketId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([ticketId, userId])
  @@index([tenantId, userId])
  @@map("ticket_watchers")
}

// Ticket Links — relationships between tickets (blocks, duplicates, related)
model TicketLink {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  fromTicketId String   @db.Uuid
  toTicketId   String   @db.Uuid
  linkType     String // BLOCKS, BLOCKED_BY, DUPLICATES, DUPLICATED_BY, RELATED_TO
  createdById  String   @db.Uuid
  createdAt    DateTime @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  fromTicket Ticket @relation("TicketLinkFrom", fields: [fromTicketId], references: [id])
  toTicket   Ticket @relation("TicketLinkTo", fields: [toTicketId], references: [id])
  createdBy  User   @relation("TicketLinkCreatedBy", fields: [createdById], references: [id])

  @@unique([fromTicketId, toTicketId, linkType])
  @@index([tenantId])
  @@index([fromTicketId])
  @@index([toTicketId])
  @@map("ticket_links")
}

// Model 14: TicketKnowledgeArticle
model TicketKnowledgeArticle {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  ticketId           String   @db.Uuid
  knowledgeArticleId String   @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  ticket           Ticket           @relation(fields: [ticketId], references: [id])
  knowledgeArticle KnowledgeArticle @relation(fields: [knowledgeArticleId], references: [id])

  @@unique([ticketId, knowledgeArticleId])
  @@index([tenantId])
  @@map("ticket_knowledge_articles")
}

// Model 15: Queue
model Queue {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  autoAssign        Boolean  @default(false)
  defaultAssigneeId String?  @db.Uuid
  userGroupId       String?  @db.Uuid
  assignmentRules   Json?
  autoCloseDays     Int? // Override tenant default for auto-close (RESOLVED → CLOSED)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  userGroup         UserGroup?         @relation(fields: [userGroupId], references: [id])
  tickets           Ticket[]
  notificationRules NotificationRule[]
  recurringTickets  RecurringTicket[]
  workflows         Workflow[]         @relation("WorkflowQueue")

  @@index([tenantId])
  @@map("queues")
}

// Model 16: SLA
model SLA {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  name                String
  p1ResponseMinutes   Int
  p1ResolutionMinutes Int
  p2ResponseMinutes   Int
  p2ResolutionMinutes Int
  p3ResponseMinutes   Int
  p3ResolutionMinutes Int
  p4ResponseMinutes   Int
  p4ResolutionMinutes Int
  businessHours       Boolean  @default(true)
  businessHoursStart  String?
  businessHoursEnd    String?
  businessDays        Int[]
  timezone            String   @default("UTC")
  autoEscalate        Boolean  @default(false)
  escalateToQueueId   String?  @db.Uuid
  escalationPolicyId  String?  @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  tickets          Ticket[]
  escalationPolicy EscalationPolicy? @relation("SlaEscalationPolicy", fields: [escalationPolicyId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("slas")
}

// Model 13b: Holiday — date-based SLA exclusions (ITIL Gap 8)
// Used by sla.service.ts business-hours calc to skip working time on holidays.
// `recurring=true` matches by month-day every year (e.g. Christmas).
model Holiday {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  date      DateTime @db.Date
  name      String
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("holidays")
}

// Model 17: Category
model Category {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  name          String
  icon          String?
  color         String?
  parentId      String?  @db.Uuid
  userGroupId   String?  @db.Uuid
  autoCloseDays Int? // Override tenant default for auto-close (RESOLVED → CLOSED)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  parent           Category?         @relation("CategoryParent", fields: [parentId], references: [id])
  children         Category[]        @relation("CategoryParent")
  userGroup        UserGroup?        @relation(fields: [userGroupId], references: [id])
  tickets          Ticket[]
  recurringTickets RecurringTicket[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

// Model 18: EmailAccount
model EmailAccount {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @db.Uuid
  name              String
  emailAddress      String
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPasswordEnc   String?
  smtpSecure        Boolean   @default(true)
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPasswordEnc   String?
  imapSecure        Boolean   @default(true)
  pollInterval      Int       @default(5)
  isActive          Boolean   @default(true)
  emailToTicket     Boolean   @default(true)
  defaultQueueId    String?   @db.Uuid
  defaultCategoryId String?   @db.Uuid
  lastPolledAt      DateTime?
  lastProcessedUid  Int       @default(0)

  // OAuth2
  authProvider          String    @default("MANUAL") // MANUAL, GOOGLE, MICROSOFT
  oauthAccessTokenEnc   String?
  oauthRefreshTokenEnc  String?
  oauthTokenExpiresAt   DateTime?
  oauthScope            String?
  oauthConnectionStatus String? // CONNECTED, DISCONNECTED, REFRESH_FAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  activityLogs EmailActivityLog[]
  pollJob      EmailPollJob?

  @@index([tenantId])
  @@map("email_accounts")
}

// ─── Email Activity Log ──────────────────────────────────────────────────────

model EmailActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  emailAccountId String   @db.Uuid
  direction      String // OUTBOUND | INBOUND
  status         String // QUEUED | SENDING | SENT | FAILED | RETRYING | PERMANENT_FAILURE | RECEIVED | POLL_STARTED | POLL_COMPLETE | POLL_FAILED
  subject        String?
  fromAddress    String?
  toAddresses    String[]
  messageId      String?
  ticketId       String?  @db.Uuid
  attemptNumber  Int      @default(1)
  errorCode      String?
  errorMessage   String?
  rawMeta        Json?
  occurredAt     DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, emailAccountId])
  @@index([tenantId, status])
  @@index([tenantId, occurredAt])
  @@index([ticketId])
  @@map("email_activity_logs")
}

model EmailPollJob {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @db.Uuid
  emailAccountId      String    @unique @db.Uuid
  lastPollAt          DateTime?
  lastUid             Int?
  consecutiveFailures Int       @default(0)
  nextPollAt          DateTime?
  isPaused            Boolean   @default(false)
  pauseReason         String?

  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([nextPollAt])
  @@map("email_poll_jobs")
}

// ─── Ticket Templates (Form-Builder) ──────────────────────────────────────────

model TicketTemplate {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @db.Uuid
  name                String
  description         String?
  icon                String? // MDI icon path for template picker
  color               String? // Accent color for template picker
  ticketType          TicketType      @default(SERVICE_REQUEST)
  isActive            Boolean         @default(true)
  isDefault           Boolean         @default(false)
  // Default values for ticket fields
  defaultPriority     TicketPriority?
  defaultCategoryId   String?         @db.Uuid
  defaultQueueId      String?         @db.Uuid
  defaultAssigneeId   String?         @db.Uuid
  defaultGroupId      String?         @db.Uuid
  defaultSlaId        String?         @db.Uuid
  defaultTags         String[]
  // Form field definitions
  fields              Json // Array of TicketTemplateField objects (see below)
  // Layout
  sections            Json? // Array of { name, description?, fieldIds[] } for grouping
  // Title/description templates
  titleTemplate       String? // Pre-filled title with {{variables}}
  descriptionTemplate String?         @db.Text // Pre-filled description with rich text
  // Tracking
  createdById         String          @db.Uuid
  position            Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation("TicketTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("ticket_templates")
}

// TicketTemplateField JSON structure:
// {
//   id: string (UUID),
//   type: "text" | "textarea" | "select" | "multiselect" | "number" | "date" | "checkbox" | "user_picker" | "attachment",
//   label: string,
//   placeholder?: string,
//   helpText?: string,
//   required: boolean,
//   defaultValue?: unknown,
//   options?: Array<{ label: string, value: string }>,  // For select/multiselect
//   validation?: { min?: number, max?: number, pattern?: string },
//   conditions?: Array<{ fieldId: string, operator: string, value: unknown }>,  // Show/hide based on other fields
//   position: number,
//   width?: "full" | "half",  // Layout
//   mapsTo?: string,  // Maps to a built-in ticket field (e.g., "impact", "urgency")
// }

// ─── Recurring Tickets ────────────────────────────────────────────────────────

model RecurringTicket {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid
  name            String
  isActive        Boolean        @default(true)
  schedule        String // Cron expression (e.g., "0 9 * * 1" = every Monday at 9am)
  timezone        String         @default("UTC")
  // Ticket template fields
  title           String
  description     String?        @db.Text
  type            TicketType     @default(INCIDENT)
  priority        TicketPriority @default(MEDIUM)
  categoryId      String?        @db.Uuid
  queueId         String?        @db.Uuid
  assignedToId    String?        @db.Uuid
  assignedGroupId String?        @db.Uuid
  tags            String[]
  customFields    Json?
  // Tracking
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdById     String         @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdBy User      @relation("RecurringTicketCreatedBy", fields: [createdById], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  queue     Queue?    @relation(fields: [queueId], references: [id])

  @@index([tenantId])
  @@index([isActive, nextRunAt])
  @@map("recurring_tickets")
}

// ─── Escalation Policies ──────────────────────────────────────────────────────

model EscalationPolicy {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  levels    Json // Array of { level, afterMinutes, action: "notify"|"reassign"|"escalate_queue", targetUserId?, targetQueueId?, notifyRoles? }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  slas   SLA[]  @relation("SlaEscalationPolicy")

  @@index([tenantId])
  @@map("escalation_policies")
}

// ─── Ticket Approval Workflows ────────────────────────────────────────────────

// Rules that determine when ticket approvals are required
model TicketApprovalRule {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  name       String
  isActive   Boolean  @default(true)
  conditions Json // { ticketType?, categoryId?, priority?, customField?, operator, value }
  approvers  Json // Array of stages: [{ stage, type: "user"|"role"|"manager", targetId?, approveMode: "any"|"all" }]
  priority   Int      @default(0) // Lower = higher priority, first match wins
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("ticket_approval_rules")
}

// Individual approval record per ticket
model TicketApproval {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  ticketId   String    @db.Uuid
  ruleId     String    @db.Uuid
  stage      Int       @default(1)
  approverId String    @db.Uuid
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  ticket   Ticket @relation(fields: [ticketId], references: [id])
  approver User   @relation("TicketApprovalApprover", fields: [approverId], references: [id])

  @@index([tenantId, ticketId])
  @@index([tenantId, approverId, status])
  @@map("ticket_approvals")
}

// ─── CSAT Surveys ─────────────────────────────────────────────────────────────

// Survey template — configurable short survey (2-5 questions)
model SurveyTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  questions   Json // Array of { id, type: "rating"|"yes_no"|"text", label, required, options? }
  isDefault   Boolean  @default(false) // One default per tenant
  isActive    Boolean  @default(true)
  trigger     String   @default("RESOLVED") // RESOLVED | CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  responses SurveyResponse[]

  @@index([tenantId])
  @@map("survey_templates")
}

// Individual survey response — one per ticket
model SurveyResponse {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  templateId String   @db.Uuid
  ticketId   String   @db.Uuid
  userId     String   @db.Uuid // The requester who filled it out
  answers    Json // Array of { questionId, value }
  rating     Int? // Extracted overall rating (1-5) for quick aggregation
  comment    String? // Extracted free-text comment for quick access
  createdAt  DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  template SurveyTemplate @relation(fields: [templateId], references: [id])
  ticket   Ticket         @relation(fields: [ticketId], references: [id])
  user     User           @relation(fields: [userId], references: [id])

  @@unique([ticketId]) // One response per ticket
  @@index([tenantId])
  @@index([tenantId, templateId])
  @@map("survey_responses")
}

// Saved Ticket Views — advanced filter presets with display customization
model SavedTicketView {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  userId        String   @db.Uuid // Creator/owner
  name          String
  description   String?
  filters       Json // All ticket field filters: status, priority, type, assignedToId, queueId, categoryId, etc.
  sortBy        String?  @default("createdAt")
  sortDir       String?  @default("desc")
  displayConfig Json? // { textColor, bgColor, badgeColors, columns[] }
  isGlobal      Boolean  @default(false) // Visible to all agents in tenant
  isDefault     Boolean  @default(false) // User's default view (at-most-one per user)
  position      Int      @default(0) // Display order
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  user        User                   @relation(fields: [userId], references: [id])
  assignments TicketViewAssignment[]

  @@index([tenantId, userId])
  @@map("saved_ticket_views")
}

// Granular view sharing — assign views to specific users or groups
model TicketViewAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  viewId      String   @db.Uuid
  userId      String?  @db.Uuid // Assign to specific user (exactly one of userId/userGroupId)
  userGroupId String?  @db.Uuid // Assign to a group
  createdAt   DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  view      SavedTicketView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  user      User?           @relation("TicketViewAssignmentUser", fields: [userId], references: [id])
  userGroup UserGroup?      @relation(fields: [userGroupId], references: [id])

  @@unique([viewId, userId])
  @@unique([viewId, userGroupId])
  @@index([tenantId, userId])
  @@index([tenantId, userGroupId])
  @@map("ticket_view_assignments")
}

// Canned Responses / Quick Replies for ticket comments
model CannedResponse {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  content     String   @db.Text
  shortcut    String? // Quick-type shortcut (e.g., "/greeting")
  category    String? // Grouping label (e.g., "Closings", "Troubleshooting")
  visibility  String   @default("PERSONAL") // PERSONAL | TEAM | GLOBAL
  createdById String   @db.Uuid
  groupId     String?  @db.Uuid // For TEAM visibility — which group can see it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  createdBy User       @relation("CannedResponseCreatedBy", fields: [createdById], references: [id])
  group     UserGroup? @relation(fields: [groupId], references: [id])

  @@index([tenantId, createdById])
  @@index([tenantId, visibility])
  @@map("canned_responses")
}

model SchedulerJob {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String?   @db.Uuid
  jobType       String // EMAIL_DELIVERY | IMAP_POLL | EMAIL_RETRY | SLA_CHECK | ESCALATION | AUTO_CLOSE
  status        String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | CANCELLED
  payload       Json?
  result        Json?
  errorMessage  String?
  attemptNumber Int       @default(1)
  maxAttempts   Int       @default(3)
  scheduledFor  DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([tenantId, jobType])
  @@map("scheduler_jobs")
}

// ─── Change Management ────────────────────────────────────────────────────────

// Model 19: Change
model Change {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid
  changeNumber       Int
  type               ChangeType   @default(NORMAL)
  title              String
  description        String?
  implementationPlan String?
  backoutPlan        String?
  testingPlan        String?
  riskLevel          RiskLevel    @default(MEDIUM)
  status             ChangeStatus @default(NEW)
  requestedById      String?      @db.Uuid
  assignedToId       String?      @db.Uuid
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  actualStart        DateTime?
  actualEnd          DateTime?
  closedAt           DateTime?
  customFields       Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  approvals             ChangeApproval[]
  activities            ChangeActivity[]
  changeApplications    ChangeApplication[]
  changeAssets          ChangeAsset[]
  cabMeetingChanges     CABMeetingChange[]
  cmdbChangeLinks       CmdbChangeLink[]
  agentUpdateDeployment AgentUpdateDeployment?

  @@unique([tenantId, changeNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scheduledStart])
  @@map("changes")
}

// Model 19b: ChangeTemplate
model ChangeTemplate {
  id                 String     @id @default(uuid()) @db.Uuid
  tenantId           String     @db.Uuid
  name               String
  description        String?
  changeType         ChangeType @default(NORMAL)
  riskLevel          RiskLevel  @default(MEDIUM)
  defaultTitle       String?
  defaultDescription String?    @db.Text
  defaultBackoutPlan String?    @db.Text
  defaultAssigneeId  String?    @db.Uuid
  defaultQueueId     String?    @db.Uuid
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("change_templates")
}

// Model 20: ChangeApproval
model ChangeApproval {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  changeId      String         @db.Uuid
  approverId    String         @db.Uuid
  status        ApprovalStatus @default(PENDING)
  sequenceOrder Int            @default(0)
  comments      String?
  decidedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  change   Change @relation(fields: [changeId], references: [id])
  approver User   @relation(fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([tenantId, changeId])
  @@index([tenantId, status])
  @@map("change_approvals")
}

// Model 21: ChangeActivity
model ChangeActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  changeId     String   @db.Uuid
  actorId      String?  @db.Uuid
  activityType String
  fieldName    String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  change Change @relation(fields: [changeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, changeId])
  @@map("change_activities")
}

// Model 22: ChangeApplication
model ChangeApplication {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  changeId      String   @db.Uuid
  applicationId String   @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  change      Change      @relation(fields: [changeId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@unique([changeId, applicationId])
  @@index([tenantId])
  @@map("change_applications")
}

// Model 23: ChangeAsset
model ChangeAsset {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  changeId  String   @db.Uuid
  assetId   String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  change Change @relation(fields: [changeId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@unique([changeId, assetId])
  @@index([tenantId])
  @@map("change_assets")
}

// Model 24: CABMeeting
model CABMeeting {
